{
  "name": "Cole's OS",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "postCreateCommand": "npm install",
  "postStartCommand": "npm start",
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "Cole's OS",
      "onAutoForward": "openBrowser",
      "visibility": "public"
    }
  }
}
